{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Priyadarshiswain/Sanjaya/main/evals/schemas/repository-manifest.schema.json",
  "title": "Sanjaya evaluation repository manifest",
  "description": "Immutable acquisition and scale metadata for controlled and public evaluation repositories.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "repositories"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "repositories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/controlledRepository"
          },
          {
            "$ref": "#/$defs/publicRepository"
          }
        ]
      }
    }
  },
  "$defs": {
    "repositoryId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "maxLength": 80
    },
    "commitSha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "repositoryPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|/)\\.\\.?(?:/|$))[^\\\\\\u0000]+$"
    },
    "httpsUrl": {
      "type": "string",
      "pattern": "^https://[^\\s]+$",
      "maxLength": 500
    },
    "languages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "csharp",
          "typescript",
          "javascript",
          "generic"
        ]
      }
    },
    "size": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trackedFiles",
        "sourceFiles",
        "sourceBytes"
      ],
      "properties": {
        "trackedFiles": {
          "type": "integer",
          "minimum": 1
        },
        "sourceFiles": {
          "type": "integer",
          "minimum": 1
        },
        "sourceBytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "controlledRepository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "originKind",
        "fixturePath",
        "commit",
        "license",
        "languages",
        "sizeBand",
        "size"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/repositoryId"
        },
        "originKind": {
          "const": "controlled_fixture"
        },
        "fixturePath": {
          "$ref": "#/$defs/repositoryPath"
        },
        "commit": {
          "$ref": "#/$defs/commitSha"
        },
        "license": {
          "const": "Apache-2.0"
        },
        "languages": {
          "$ref": "#/$defs/languages"
        },
        "sizeBand": {
          "const": "controlled"
        },
        "size": {
          "$ref": "#/$defs/size"
        }
      }
    },
    "publicRepository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "originKind",
        "url",
        "commit",
        "license",
        "licenseUrl",
        "languages",
        "sizeBand",
        "size"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/repositoryId"
        },
        "originKind": {
          "const": "public_git"
        },
        "url": {
          "$ref": "#/$defs/httpsUrl"
        },
        "commit": {
          "$ref": "#/$defs/commitSha"
        },
        "license": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "licenseUrl": {
          "$ref": "#/$defs/httpsUrl"
        },
        "languages": {
          "$ref": "#/$defs/languages"
        },
        "sizeBand": {
          "enum": [
            "small",
            "medium",
            "large"
          ]
        },
        "size": {
          "$ref": "#/$defs/size"
        }
      }
    }
  }
}
