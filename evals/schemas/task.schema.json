{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Priyadarshiswain/Sanjaya/main/evals/schemas/task.schema.json",
  "title": "Sanjaya evaluation task",
  "description": "A frozen repository-discovery question and its independently reviewed scoring ground truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "category",
    "difficulty",
    "repository",
    "languages",
    "sizeBand",
    "indexState",
    "question",
    "groundTruth",
    "scorerVersion"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "pattern": "^SJ-EVAL-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "category": {
      "enum": [
        "orientation",
        "target_location",
        "definition_ambiguity",
        "references_source",
        "exact_text",
        "typescript_javascript_structure",
        "recent_changes",
        "negative_recovery"
      ]
    },
    "difficulty": {
      "enum": [
        "basic",
        "intermediate",
        "advanced"
      ]
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "commit"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/repositoryId"
        },
        "commit": {
          "$ref": "#/$defs/commitSha"
        }
      }
    },
    "languages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "csharp",
          "typescript",
          "javascript",
          "generic"
        ]
      }
    },
    "sizeBand": {
      "enum": [
        "controlled",
        "small",
        "medium",
        "large"
      ]
    },
    "indexState": {
      "enum": [
        "none",
        "warm",
        "stale"
      ]
    },
    "question": {
      "type": "string",
      "minLength": 20,
      "maxLength": 2000
    },
    "groundTruth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expectedOutcome",
        "requiredClaims",
        "forbiddenClaims"
      ],
      "properties": {
        "expectedOutcome": {
          "enum": [
            "answerable",
            "absent",
            "ambiguous",
            "unsupported"
          ]
        },
        "requiredClaims": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/requiredClaim"
          }
        },
        "forbiddenClaims": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/forbiddenClaim"
          }
        }
      }
    },
    "scorerVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "tags": {
      "type": "array",
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$",
        "maxLength": 40
      }
    }
  },
  "$defs": {
    "repositoryId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "maxLength": 80
    },
    "commitSha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "claimKey": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$",
      "maxLength": 80
    },
    "repositoryPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|/)\\.\\.?(?:/|$))[^\\\\\\u0000]+$"
    },
    "lineEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "startLine",
        "endLine"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/repositoryPath"
        },
        "startLine": {
          "type": "integer",
          "minimum": 1
        },
        "endLine": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "requiredClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "description",
        "matchMode",
        "acceptedValues",
        "acceptableEvidence"
      ],
      "properties": {
        "key": {
          "$ref": "#/$defs/claimKey"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "matchMode": {
          "enum": [
            "exact",
            "one_of",
            "set_exact",
            "citation_only"
          ]
        },
        "acceptedValues": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        },
        "acceptableEvidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lineEvidence"
          }
        }
      }
    },
    "forbiddenClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "severity"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "severity": {
          "enum": [
            "critical",
            "major",
            "minor"
          ]
        }
      }
    }
  }
}
