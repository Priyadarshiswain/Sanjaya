{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Priyadarshiswain/Sanjaya/main/evals/schemas/answer.schema.json",
  "title": "Sanjaya evaluation agent answer",
  "description": "The arm-independent structured final answer required from an evaluated agent.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "taskId",
    "answer",
    "claims",
    "unknowns",
    "confidence"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "taskId": {
      "type": "string",
      "pattern": "^SJ-EVAL-[0-9]{4}$"
    },
    "answer": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "claims": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "unknowns": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "$defs": {
    "claimKey": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$",
      "maxLength": 80
    },
    "repositoryPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|/)\\.\\.?(?:/|$))[^\\\\\\u0000]+$"
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "startLine",
        "endLine"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/repositoryPath"
        },
        "startLine": {
          "type": "integer",
          "minimum": 1
        },
        "endLine": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "value",
        "evidence"
      ],
      "properties": {
        "key": {
          "$ref": "#/$defs/claimKey"
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "evidence": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "$ref": "#/$defs/evidence"
          }
        }
      }
    }
  }
}
