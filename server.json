{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Priyadarshiswain/sanjaya",
  "title": "Sanjaya",
  "description": "Local-first codebase discovery for AI agents, with precise navigation and verifiable evidence.",
  "repository": {
    "url": "https://github.com/Priyadarshiswain/Sanjaya",
    "source": "github",
    "id": "1307595672"
  },
  "version": "0.1.1",
  "websiteUrl": "https://github.com/Priyadarshiswain/Sanjaya",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "sanjaya-mcp",
      "version": "0.1.1",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "--root"
        },
        {
          "type": "positional",
          "valueHint": "repository_root",
          "description": "Absolute path to the repository root Sanjaya may inspect.",
          "format": "filepath",
          "isRequired": true
        }
      ]
    }
  ]
}
